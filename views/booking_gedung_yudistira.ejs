<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking - Gedung Yudistira</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
</head>

<body>
    <%- include('partials/header') %>

        <main class="container">
            <h2 class="text-center">Book Your Seat in Gedung Yudistira</h2>
            <form action="/booking_gedung_yudistira/book" method="POST">
                <div class="form-group">
                    <label for="nama">Nama:</label>
                    <input type="text" id="nama" name="nama" required>
                </div>
                <div class="form-group">
                    <label for="distrik">Distrik:</label>
                    <select id="distrik" name="distrik" required>
                        <option value="">-- Pilih Distrik --</option>
                        <% distrikList.forEach(distrik=> { %>
                            <option value="<%= distrik.id %>">
                                <%= distrik.nama_distrik %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label for="asal_sidang">Asal Sidang:</label>
                    <select id="asal_sidang" name="asal_sidang" required>
                        <option value="">-- Pilih Asal Sidang --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="no_wa">No WA:</label>
                    <input type="text" id="no_wa" name="no_wa" required>
                </div>
                <div class="form-group">
                    <label for="jumlah_seat">Jumlah Seat:</label>
                    <input type="number" id="jumlah_seat" name="jumlah_seat" min="1" max="1" value="1" readonly
                        required>
                </div>
                <input type="hidden" id="blok_booking" name="blok_booking" value="Gedung 1">
                <button type="submit" class="btn">Book Now</button>
            </form>
        </main>

        <%- include('partials/footer') %>

            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const distrikSelect = document.getElementById('distrik');
                    const asalSidangSelect = document.getElementById('asal_sidang');

                    distrikSelect.addEventListener('change', () => {
                        const idDistrik = distrikSelect.value;
                        asalSidangSelect.innerHTML = '<option value="">-- Pilih Asal Sidang --</option>';

                        if (idDistrik) {
                            fetch(`/booking_gedung_hastina/get-sidang/${idDistrik}`)
                                .then(response => response.json())
                                .then(data => {
                                    data.forEach(sidang => {
                                        const option = document.createElement('option');
                                        option.value = sidang.nama_sidang;
                                        option.textContent = sidang.nama_sidang;
                                        asalSidangSelect.appendChild(option);
                                    });
                                })
                                .catch(error => console.error('Error fetching sidang jemaat:', error));
                        }
                    });
                });
            </script>
</body>

</html>